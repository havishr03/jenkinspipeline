pipeline{
	agent any
	
		stages{
		stage('checkout'){
			steps{
				git branch:'main',url:'https://github.com/havishr03/Gradlejenkinspipeline.git'
			}
		}
		stage('Build'){
			steps{
				sh './gradle build'
			}
		}
		stage('Test'){
			steps{
				sh './gradle test'
			}
		}
		stage('Run Application'){
			steps{
				sh './gradle run'
			}
		}
	}
}
