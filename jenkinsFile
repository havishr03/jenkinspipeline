pipeline{
	agent any
	
		stages{
		stage('checkout'){
			steps{
				git branch:'main',url:'https://github.com/havishr03/jenkinspipeline.git'
			}
		}
		stage('Build'){
			steps{
				sh './gradlew build'
			}
		}
		stage('Test'){
			steps{
				sh './gradlew test'
			}
		}
		stage('Run Application'){
			steps{
				sh './gradlew run'
			}
		}
	}
}
