pipeline{
	agent any
	
		stages{
		stage('checkout'){
			steps{
				git branch:'master',url:'https://github.com/havishr03/Gradlejenkinspipeline.git'
			}
		}
		stage('Build'){
			steps{
				sh './gradle build'
			}
		}
		stage('Test'){
			steps{
				sh './gradle test'
			}
		}
		stage('Run Application'){
			steps{
				sh './gradle run'
			}
		}
		post{
			success{
				echo 'Build and deployment successful'
			}
			failure{
				echo 'Build failed'
			}
		}
	}
}
